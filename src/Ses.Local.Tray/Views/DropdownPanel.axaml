<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ses.Local.Tray.ViewModels"
        x:Class="Ses.Local.Tray.Views.DropdownPanel"
        Title="ses-local"
        Width="400"
        SizeToContent="Height"
        MaxHeight="600"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="True"
        WindowStartupLocation="Manual"
        Topmost="True">

  <Window.Styles>
    <!-- Tab button base -->
    <Style Selector="Button.tabBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.tabBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FF3A3A3C"/>
    </Style>
    <Style Selector="Button.tabBtn.active">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush" Value="#FF0A84FF"/>
    </Style>

    <!-- Section header -->
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="Margin" Value="16,12,0,4"/>
    </Style>

    <!-- Feature row -->
    <Style Selector="Border.featureRow">
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="BorderBrush" Value="#3A3A3C"/>
    </Style>

    <!-- Status dot -->
    <Style Selector="Ellipse.statusDot">
      <Setter Property="Width" Value="8"/>
      <Setter Property="Height" Value="8"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <!-- Footer button -->
    <Style Selector="Button.footerBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </Window.Styles>

  <!-- Outer rounded container with shadow -->
  <Border CornerRadius="8" ClipToBounds="True"
          BoxShadow="0 4 20 0 #80000000">
    <DockPanel>

      <!-- ── Header ─────────────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Top" Background="#FF1C1C1E" Padding="16,12">
        <Grid ColumnDefinitions="Auto,*">
          <!-- Status dot -->
          <Ellipse Classes="statusDot" VerticalAlignment="Center" Width="10" Height="10" Margin="0,0,10,0"
                   Fill="{Binding StatusDotColor, Converter={StaticResource DotColorConverter}}"/>
          <StackPanel Grid.Column="1" Orientation="Vertical">
            <TextBlock Text="ses-local" FontSize="16" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#888888"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── Tab bar ────────────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Top" Background="#FF252527">
        <StackPanel Orientation="Horizontal">
          <Button Classes="tabBtn" Content="Status"
                  Classes.active="{Binding IsStatusTab}"
                  Click="OnStatusTabClick"/>
          <Button Classes="tabBtn" Content="CC Config"
                  Classes.active="{Binding IsCcConfigTab}"
                  Click="OnCcConfigTabClick"/>
          <Button Classes="tabBtn" Content="Import"
                  Classes.active="{Binding IsImportTab}"
                  Click="OnImportTabClick"/>
          <Button Classes="tabBtn" Content="⚙"
                  Classes.active="{Binding IsSettingsTab}"
                  Click="OnSettingsTabClick"/>
        </StackPanel>
      </Border>

      <!-- ── Footer ────────────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Bottom" Background="#FF1C1C1E" Padding="12,6">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                     FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Classes="footerBtn" Content="Troubleshoot"
                  Margin="0,0,4,0" Click="OnTroubleshootClick"/>
          <Button Grid.Column="2" Classes="footerBtn" Content="Quit"
                  Click="OnQuitClick"/>
        </Grid>
      </Border>

      <!-- ── Content area ──────────────────────────────────────────────── -->
      <Border Background="#FF2C2C2E">
        <ScrollViewer MaxHeight="440">
          <Panel>

          <!-- Status tab -->
          <StackPanel IsVisible="{Binding IsStatusTab}">

            <!-- First-run banner -->
            <Border IsVisible="{Binding IsFirstRun}"
                    Background="#0A3055" Padding="16,10" Margin="0,0,0,1">
              <TextBlock Text="Welcome! Toggle features below to get started."
                         Foreground="#7EC8E3" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="CONVERSATION SYNC" Classes="sectionHeader"/>
            <ItemsControl ItemsSource="{Binding ConvSyncFeatures}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="featureRow">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                      <Ellipse Classes="statusDot" VerticalAlignment="Center"
                               Fill="{Binding Dot, Converter={StaticResource DotColorConverter}}"/>
                      <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"/>
                        <TextBlock Text="{Binding LastActivity}" FontSize="11" Foreground="#888888"/>
                      </StackPanel>
                      <Border Grid.Column="2" IsVisible="{Binding IsComingSoon}"
                              Background="#333333" CornerRadius="4" Padding="4,2" Margin="0,0,8,0">
                        <TextBlock Text="soon" FontSize="10" Foreground="#888888"/>
                      </Border>
                      <ToggleSwitch Grid.Column="3" IsChecked="{Binding IsEnabled}"
                                    IsEnabled="{Binding IsComingSoon, Converter={x:Static BoolConverters.Not}}"
                                    OnContent="" OffContent=""
                                    Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="MEMORY" Classes="sectionHeader"/>
            <ItemsControl ItemsSource="{Binding MemoryFeatures}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="featureRow">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Ellipse Classes="statusDot" VerticalAlignment="Center"
                               Fill="{Binding Dot, Converter={StaticResource DotColorConverter}}"/>
                      <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"/>
                        <TextBlock Text="{Binding LastActivity}" FontSize="11" Foreground="#888888"/>
                      </StackPanel>
                      <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                    OnContent="" OffContent=""
                                    Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>

          <!-- CC Config tab -->
          <StackPanel IsVisible="{Binding IsCcConfigTab}" Margin="16,24">
            <TextBlock Text="Claude Code configuration"
                       FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
            <TextBlock Text="Coming in TRAY-1/2/3"
                       FontSize="13" Foreground="#888888" TextWrapping="Wrap"/>
          </StackPanel>

          <!-- Import tab -->
          <StackPanel IsVisible="{Binding IsImportTab}" Margin="16,24">
            <TextBlock Text="Conversation import"
                       FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
            <TextBlock Text="Coming in TRAY-5"
                       FontSize="13" Foreground="#888888" TextWrapping="Wrap"/>
          </StackPanel>

          <!-- Settings tab -->
          <StackPanel IsVisible="{Binding IsSettingsTab}" Margin="16,16" Spacing="12">
            <TextBlock Text="ACCOUNT" Classes="sectionHeader" Margin="0,0,0,4"/>
            <Border Classes="featureRow">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Vertical">
                  <TextBlock Text="{Binding UserDisplayName}" FontSize="13" Foreground="White"/>
                  <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#888888"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Sign Out"
                        FontSize="12" Background="Transparent" Foreground="#888888"
                        BorderThickness="0" Click="OnSignOutClick"/>
              </Grid>
            </Border>
            <TextBlock Text="Settings — more options coming soon"
                       FontSize="13" Foreground="#888888" TextWrapping="Wrap" Margin="0,8,0,0"/>
          </StackPanel>

          </Panel>
        </ScrollViewer>
      </Border>

    </DockPanel>
  </Border>
</Window>
