<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ses.Local.Tray.ViewModels"
        xmlns:services="using:Ses.Local.Tray.Services"
        x:Class="Ses.Local.Tray.Views.DropdownPanel"
        Title="ses-local"
        Width="400"
        SizeToContent="Height"
        MaxHeight="600"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="True"
        WindowStartupLocation="Manual"
        Topmost="True">

  <Window.Styles>
    <!-- Tab button base -->
    <Style Selector="Button.tabBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.tabBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FF3A3A3C"/>
    </Style>
    <Style Selector="Button.tabBtn.active">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush" Value="#FF0A84FF"/>
    </Style>

    <!-- Section header -->
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="Margin" Value="16,12,0,4"/>
    </Style>

    <!-- Feature row -->
    <Style Selector="Border.featureRow">
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="BorderBrush" Value="#3A3A3C"/>
    </Style>

    <!-- Status dot -->
    <Style Selector="Ellipse.statusDot">
      <Setter Property="Width" Value="8"/>
      <Setter Property="Height" Value="8"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <!-- Footer button -->
    <Style Selector="Button.footerBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Small icon button (remove ×) -->
    <Style Selector="Button.iconBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#555555"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="4,0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#FF453A"/>
    </Style>

    <!-- Inline form input -->
    <Style Selector="TextBox.formInput">
      <Setter Property="Background" Value="#252527"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#555555"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Danger button (confirm remove) -->
    <Style Selector="Button.dangerBtn">
      <Setter Property="Background" Value="#7B1D1D"/>
      <Setter Property="Foreground" Value="#FF6B6B"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="8,3"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- Accent button -->
    <Style Selector="Button.accentBtn">
      <Setter Property="Background" Value="#0A84FF"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- Notification row button -->
    <Style Selector="Button.notifRow">
      <Setter Property="Background" Value="#3D2A00"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="BorderBrush" Value="#5A3D00"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.notifRow:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#4D3400"/>
    </Style>

    <!-- Secondary button -->
    <Style Selector="Button.secondaryBtn">
      <Setter Property="Background" Value="#3A3A3C"/>
      <Setter Property="Foreground" Value="#CCCCCC"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
  </Window.Styles>

  <!-- Outer rounded container with shadow -->
  <Border CornerRadius="8" ClipToBounds="True"
          BoxShadow="0 4 20 0 #80000000">
    <DockPanel>

      <!-- ── Header ─────────────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Top" Background="#FF1C1C1E" Padding="16,12">
        <Grid ColumnDefinitions="Auto,*">
          <!-- Status dot -->
          <Ellipse Classes="statusDot" VerticalAlignment="Center" Width="10" Height="10" Margin="0,0,10,0"
                   Fill="{Binding StatusDotColor, Converter={StaticResource DotColorConverter}}"/>
          <StackPanel Grid.Column="1" Orientation="Vertical">
            <TextBlock Text="ses-local" FontSize="16" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#888888"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── Notification bar (above tabs) ─────────────────────────────── -->
      <ItemsControl DockPanel.Dock="Top" IsVisible="{Binding HasNotifications}"
                    ItemsSource="{Binding ActiveNotifications}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="services:NotificationEntry">
            <Button Classes="notifRow" Click="OnNotificationActionClick" HorizontalAlignment="Stretch">
              <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,6">
                <TextBlock Text="{Binding Icon}" Foreground="#FF8C00"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="#FFCC88"
                           FontSize="12" VerticalAlignment="Center" TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="2" Classes="iconBtn" Content="×"
                        Click="OnDismissNotificationClick" Margin="8,0,0,0"/>
              </Grid>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- ── Tab bar ────────────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Top" Background="#FF252527">
        <StackPanel Orientation="Horizontal">
          <Button Classes="tabBtn" Content="Status"
                  Classes.active="{Binding IsStatusTab}"
                  Click="OnStatusTabClick"/>
          <Button Classes="tabBtn" Content="CC Config"
                  Classes.active="{Binding IsCcConfigTab}"
                  Click="OnCcConfigTabClick"/>
          <Button Classes="tabBtn" Content="Import"
                  Classes.active="{Binding IsImportTab}"
                  Click="OnImportTabClick"/>
          <Button Classes="tabBtn" Content="⚙"
                  Classes.active="{Binding IsSettingsTab}"
                  Click="OnSettingsTabClick"/>
        </StackPanel>
      </Border>

      <!-- ── Footer ────────────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Bottom" Background="#FF1C1C1E" Padding="12,6">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                     FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Classes="footerBtn" Content="Troubleshoot"
                  Margin="0,0,4,0" Click="OnTroubleshootClick"/>
          <Button Grid.Column="2" Classes="footerBtn" Content="Quit"
                  Click="OnQuitClick"/>
        </Grid>
      </Border>

      <!-- ── Content area ──────────────────────────────────────────────── -->
      <Border Background="#FF2C2C2E">
        <ScrollViewer MaxHeight="440">
          <Panel>

          <!-- Status tab -->
          <StackPanel IsVisible="{Binding IsStatusTab}">

            <!-- First-run banner -->
            <Border IsVisible="{Binding IsFirstRun}"
                    Background="#0A3055" Padding="16,10" Margin="0,0,0,1">
              <TextBlock Text="Welcome! Toggle features below to get started."
                         Foreground="#7EC8E3" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- DAEMON section -->
            <TextBlock Text="DAEMON" Classes="sectionHeader"/>
            <Border Classes="featureRow">
              <Grid ColumnDefinitions="Auto,*">
                <Ellipse Classes="statusDot" VerticalAlignment="Center"
                         Fill="{Binding StatusDotColor, Converter={StaticResource DotColorConverter}}"/>
                <StackPanel Grid.Column="1" Orientation="Vertical">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="White"/>
                    <TextBlock Text="{Binding DaemonUptime, StringFormat='Uptime: {0}'}"
                               FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="{Binding UserDisplayName}" FontSize="11" Foreground="#888888"/>
                </StackPanel>
              </Grid>
            </Border>

            <!-- CONVERSATION SYNC section -->
            <TextBlock Text="CONVERSATION SYNC" Classes="sectionHeader"/>
            <ItemsControl ItemsSource="{Binding ConvSyncFeatures}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="featureRow">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                      <Ellipse Classes="statusDot" VerticalAlignment="Center"
                               Fill="{Binding Dot, Converter={StaticResource DotColorConverter}}"/>
                      <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"/>
                        <TextBlock Text="{Binding LastActivity}" FontSize="11" Foreground="#888888"/>
                      </StackPanel>
                      <Border Grid.Column="2" IsVisible="{Binding IsComingSoon}"
                              Background="#333333" CornerRadius="4" Padding="4,2" Margin="0,0,8,0">
                        <TextBlock Text="soon" FontSize="10" Foreground="#888888"/>
                      </Border>
                      <ToggleSwitch Grid.Column="3" IsChecked="{Binding IsEnabled}"
                                    IsEnabled="{Binding IsComingSoon, Converter={x:Static BoolConverters.Not}}"
                                    OnContent="" OffContent=""
                                    Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- MEMORY section -->
            <TextBlock Text="MEMORY" Classes="sectionHeader"/>
            <ItemsControl ItemsSource="{Binding MemoryFeatures}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="featureRow">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Ellipse Classes="statusDot" VerticalAlignment="Center"
                               Fill="{Binding Dot, Converter={StaticResource DotColorConverter}}"/>
                      <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"/>
                        <TextBlock Text="{Binding LastActivity}" FontSize="11" Foreground="#888888"/>
                      </StackPanel>
                      <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                    OnContent="" OffContent=""
                                    Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- TOTALS section -->
            <TextBlock Text="TOTALS" Classes="sectionHeader"/>
            <Border Classes="featureRow">
              <StackPanel Orientation="Vertical" Spacing="3">
                <TextBlock Text="{Binding TotalConversationsText}" FontSize="12" Foreground="White"/>
                <TextBlock Text="{Binding TotalMessagesText}"      FontSize="12" Foreground="White"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Local DB:" FontSize="11" Foreground="#888888"/>
                  <TextBlock Text="{Binding LocalDbSizeText}" FontSize="11" Foreground="#888888"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Oldest:" FontSize="11" Foreground="#888888"/>
                  <TextBlock Text="{Binding OldestConversationText}" FontSize="11" Foreground="#888888"/>
                  <TextBlock Text="· Newest:" FontSize="11" Foreground="#888888"/>
                  <TextBlock Text="{Binding NewestConversationText}" FontSize="11" Foreground="#888888"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- COMPONENTS section -->
            <TextBlock Text="COMPONENTS" Classes="sectionHeader"/>
            <ItemsControl ItemsSource="{Binding Components}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="featureRow">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Ellipse Classes="statusDot" VerticalAlignment="Center"
                               Fill="{Binding Dot, Converter={StaticResource DotColorConverter}}"/>
                      <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#888888"/>
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding Version}" FontSize="11"
                                 Foreground="#555555" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>

          <!-- CC Config tab -->
          <StackPanel IsVisible="{Binding IsCcConfigTab}">

            <!-- MODEL -->
            <TextBlock Text="MODEL" Classes="sectionHeader"/>
            <Border Classes="featureRow">
              <ComboBox ItemsSource="{Binding CcAvailableModels}"
                        SelectedItem="{Binding CcModelName, Mode=OneWay}"
                        Background="#3A3A3C" Foreground="White"
                        BorderThickness="0" FontSize="12"
                        SelectionChanged="OnModelSelectionChanged"/>
            </Border>
            <TextBlock Text="Restart Claude Code for model changes to take effect."
                       FontSize="11" Foreground="#555555" Margin="16,2,16,0"/>

            <!-- PERMISSIONS -->
            <TextBlock Text="PERMISSIONS" Classes="sectionHeader"/>
            <Border Classes="featureRow">
              <StackPanel Orientation="Vertical" Spacing="3">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Allow: " FontSize="12" Foreground="#888888"/>
                  <TextBlock Text="{Binding CcPermissionsAllow}" FontSize="12" Foreground="White"
                             TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Deny: " FontSize="12" Foreground="#888888"/>
                  <TextBlock Text="{Binding CcPermissionsDeny}" FontSize="12" Foreground="White"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- CLAUDE CODE MCP SERVERS -->
            <TextBlock Text="CLAUDE CODE MCP SERVERS" Classes="sectionHeader"/>

            <ItemsControl ItemsSource="{Binding CcMcpServers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:McpServerViewModel">
                  <Border Classes="featureRow">
                    <Panel>
                      <!-- Normal state -->
                      <Grid IsVisible="{Binding ShowNormalState}" ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                        <Ellipse Classes="statusDot" VerticalAlignment="Center"
                                 Fill="{Binding Dot, Converter={StaticResource DotColorConverter}}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                   FontSize="13" Foreground="White" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                          <TextBlock Text="{Binding ConnectionType}" FontSize="11" Foreground="#888888"/>
                          <TextBlock Text="{Binding Target}" FontSize="11" Foreground="#666666"
                                     TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="3" Classes="iconBtn" Content="×"
                                IsVisible="{Binding ShowRemoveButton}"
                                Click="OnRemoveMcpClick"/>
                        <ToggleSwitch Grid.Column="4" IsChecked="{Binding IsEnabled}"
                                      OnContent="" OffContent=""
                                      Checked="OnMcpToggled" Unchecked="OnMcpToggled"/>
                      </Grid>

                      <!-- Confirm-remove state -->
                      <Grid IsVisible="{Binding ShowRemoveConfirm}" ColumnDefinitions="*,Auto,Auto"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name, StringFormat='Remove &quot;{0}&quot;?'}"
                                   FontSize="12" Foreground="#FF6B6B" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="secondaryBtn" Content="Cancel"
                                Margin="0,0,6,0" Click="OnCancelRemoveMcpClick"/>
                        <Button Grid.Column="2" Classes="dangerBtn" Content="Remove"
                                Click="OnConfirmRemoveMcpClick"/>
                      </Grid>
                    </Panel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- MCP action buttons -->
            <Border Padding="16,8,16,4">
              <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                <Button Classes="footerBtn" Content="+ Add Server..."
                        Foreground="#0A84FF" FontSize="12"
                        Click="OnAddMcpServerClick"/>
                <Button Grid.Column="2" Classes="footerBtn"
                        Content="{Binding RestartStatus, FallbackValue='Restart All'}"
                        Foreground="#888888" FontSize="12"
                        IsEnabled="{Binding IsRestarting, Converter={x:Static BoolConverters.Not}}"
                        Click="OnRestartAllMcpClick"/>
              </Grid>
            </Border>

            <!-- Inline add-server form -->
            <Border IsVisible="{Binding IsAddFormVisible}"
                    Background="#252527" Margin="8,0,8,8" Padding="12,10"
                    CornerRadius="6">
              <StackPanel Spacing="8">
                <TextBlock Text="Add MCP Server" FontSize="13" FontWeight="SemiBold" Foreground="White"/>

                <Grid ColumnDefinitions="70,*" RowDefinitions="Auto" VerticalAlignment="Center">
                  <TextBlock Text="Name" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                  <TextBox Grid.Column="1" Classes="formInput"
                           Text="{Binding AddName}" Watermark="e.g. context7"/>
                </Grid>

                <Grid ColumnDefinitions="70,*">
                  <TextBlock Text="Type" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <RadioButton Content="stdio" IsChecked="{Binding AddIsStdio}"
                                 Foreground="White" FontSize="12"/>
                    <RadioButton Content="HTTP" IsChecked="{Binding AddIsHttp}"
                                 Foreground="White" FontSize="12"/>
                  </StackPanel>
                </Grid>

                <!-- stdio fields -->
                <StackPanel IsVisible="{Binding AddIsStdio}" Spacing="6">
                  <Grid ColumnDefinitions="70,*">
                    <TextBlock Text="Command" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Classes="formInput"
                             Text="{Binding AddCommand}" Watermark="e.g. npx or /usr/local/bin/mcp"/>
                  </Grid>
                  <Grid ColumnDefinitions="70,*">
                    <TextBlock Text="Args" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Classes="formInput"
                             Text="{Binding AddArgs}" Watermark="space-separated args (optional)"/>
                  </Grid>
                </StackPanel>

                <!-- HTTP fields -->
                <Grid IsVisible="{Binding AddIsHttp}" ColumnDefinitions="70,*">
                  <TextBlock Text="URL" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                  <TextBox Grid.Column="1" Classes="formInput"
                           Text="{Binding AddUrl}" Watermark="https://"/>
                </Grid>

                <!-- Validation error -->
                <TextBlock IsVisible="{Binding HasAddValidationError}"
                           Text="{Binding AddValidationError}"
                           FontSize="11" Foreground="#FF6B6B"/>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                  <Button Classes="secondaryBtn" Content="Cancel" Click="OnCancelAddMcpClick"/>
                  <Button Classes="accentBtn" Content="Add Server" Click="OnConfirmAddMcpClick"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- CLAUDE DESKTOP MCP SERVERS -->
            <TextBlock Text="CLAUDE DESKTOP MCP SERVERS" Classes="sectionHeader"/>

            <ItemsControl ItemsSource="{Binding DesktopMcpServers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:McpServerViewModel">
                  <Border Classes="featureRow">
                    <Grid ColumnDefinitions="Auto,Auto,*">
                      <Ellipse Classes="statusDot" VerticalAlignment="Center"
                               Fill="{Binding Dot, Converter={StaticResource DotColorConverter}}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Name}"
                                 FontSize="13" Foreground="White" VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                      <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionType}" FontSize="11" Foreground="#888888"/>
                        <TextBlock Text="{Binding Target}" FontSize="11" Foreground="#666666"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- HOOKS -->
            <TextBlock Text="HOOKS" Classes="sectionHeader"/>
            <Border Classes="featureRow">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Ellipse Classes="statusDot" VerticalAlignment="Center"
                         Fill="{Binding HooksStatusDot, Converter={StaticResource DotColorConverter}}"/>
                <StackPanel Grid.Column="1" Orientation="Vertical">
                  <TextBlock Text="{Binding CcHooksSummary}" FontSize="13" Foreground="White"/>
                  <TextBlock Text="{Binding HooksStatusText}" FontSize="11" Foreground="#888888"/>
                  <TextBlock Text="{Binding HooksLastActivity, StringFormat='Last activity: {0}'}"
                             FontSize="11" Foreground="#666666"
                             IsVisible="{Binding HasLastActivity}"/>
                </StackPanel>
                <Button Grid.Column="2" Content="{Binding HooksToggleLabel}" Classes="footerBtn"
                        Foreground="#0A84FF" FontSize="12" Margin="0,0,4,0"
                        Click="OnToggleHooksClick"/>
                <Button Grid.Column="3" Content="Logs" Classes="footerBtn"
                        Foreground="#0A84FF" FontSize="12"
                        Click="OnViewLogsClick"/>
              </Grid>
            </Border>
            <!-- Hook log panel (expandable) -->
            <Border IsVisible="{Binding IsLogsExpanded}" Background="#1C1C1E" Padding="12,8">
              <ItemsControl ItemsSource="{Binding RecentLogs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="110,70,*" Margin="0,1">
                      <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                 FontSize="10" Foreground="#555555" FontFamily="Courier New"/>
                      <TextBlock Grid.Column="1" Text="{Binding ToolName}" FontSize="10" Foreground="#888888"/>
                      <TextBlock Grid.Column="2" Text="{Binding FilePath}" FontSize="10" Foreground="#666666"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>

            <!-- SETTINGS FILES -->
            <TextBlock Text="SETTINGS FILES" Classes="sectionHeader"/>
            <Border Classes="featureRow">
              <StackPanel Orientation="Vertical" Spacing="6">
                <StackPanel Orientation="Vertical">
                  <TextBlock Text="~/.claude/settings.json" FontSize="12" Foreground="White"/>
                  <TextBlock Text="{Binding CcSettingsFileAge, StringFormat='Modified: {0}'}"
                             FontSize="11" Foreground="#888888"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                  <TextBlock Text="~/.claude/settings.local.json" FontSize="12" Foreground="White"/>
                  <TextBlock Text="{Binding CcLocalSettingsFileAge, StringFormat='Modified: {0}'}"
                             FontSize="11" Foreground="#888888"/>
                </StackPanel>
              </StackPanel>
            </Border>
            <Border Padding="16,8">
              <Button Content="Open in Editor" Classes="footerBtn"
                      Foreground="#0A84FF" FontSize="12"
                      Click="OnOpenCcSettingsClick"/>
            </Border>

          </StackPanel>

          <!-- Import tab -->
          <StackPanel IsVisible="{Binding IsImportTab}" Spacing="0">

            <!-- Import Wizard (TRAY-5) — DataContext switches to ImportWizard sub-VM -->
            <Panel DataContext="{Binding ImportWizard}">

              <!-- Step 1: Choose Source -->
              <StackPanel IsVisible="{Binding IsSourceStep}" Margin="16,16" Spacing="12">
                <TextBlock Text="Import Conversation History"
                           FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="{Binding LastImportInfo}" FontSize="11" Foreground="#888888"
                           IsVisible="{Binding LastImportInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <WrapPanel HorizontalAlignment="Left" ItemSpacing="10">
                  <Button Width="110" Height="60" Background="#FF3A3A3C" CornerRadius="6"
                          BorderThickness="1" BorderBrush="#FF555555"
                          Click="OnImportSourceClaudeClick">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                      <TextBlock Text="Claude" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text=".json" Foreground="#888888" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Width="110" Height="60" Background="#FF3A3A3C" CornerRadius="6"
                          BorderThickness="1" BorderBrush="#FF555555"
                          Click="OnImportSourceChatGptClick">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                      <TextBlock Text="ChatGPT" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text=".zip" Foreground="#888888" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Width="110" Height="60" Background="#FF3A3A3C" CornerRadius="6"
                          BorderThickness="1" BorderBrush="#FF555555"
                          Click="OnImportSourceGeminiClick">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                      <TextBlock Text="Gemini" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text=".zip" Foreground="#888888" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </WrapPanel>
                <TextBlock Text="Select the AI platform to import conversations from."
                           FontSize="12" Foreground="#888888" TextWrapping="Wrap"/>
              </StackPanel>

              <!-- Step 2: Instructions + File Picker -->
              <StackPanel IsVisible="{Binding IsInstructionsStep}" Margin="16,16" Spacing="10">
                <Grid ColumnDefinitions="Auto,*">
                  <Button Content="←" Background="Transparent" Foreground="#888888"
                          BorderThickness="0" FontSize="14" Padding="0,0,8,0"
                          Click="OnImportBackClick"/>
                  <TextBlock Grid.Column="1" Text="{Binding SourceLabel, StringFormat='Import from {0}'}"
                             FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding InstructionsText}" FontSize="12" Foreground="#888888"
                           TextWrapping="Wrap" LineHeight="18"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                  <Button Content="Select File..." Background="#FF3A3A3C" Foreground="White"
                          BorderThickness="0" CornerRadius="4" Padding="10,6"
                          Click="OnPickFileClick"/>
                  <TextBlock Text="{Binding FileName}" Foreground="#AAAAAA" FontSize="12"
                             VerticalAlignment="Center"
                             IsVisible="{Binding FileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <Button Content="Import →" Background="#FF0A84FF" Foreground="White"
                        BorderThickness="0" CornerRadius="4" Padding="12,6"
                        IsEnabled="{Binding FileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Click="OnStartImportClick"/>
              </StackPanel>

              <!-- Step 3: Progress -->
              <StackPanel IsVisible="{Binding IsProgressStep}" Margin="16,16" Spacing="10">
                <TextBlock Text="{Binding ProgressStatus}" FontSize="13" FontWeight="SemiBold"
                           Foreground="White" TextWrapping="Wrap"/>
                <ProgressBar IsIndeterminate="True" Height="6" CornerRadius="3"
                             Foreground="#FF0A84FF" Background="#FF3A3A3C"/>
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Sessions imported:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressSessions, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Messages:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressMessages, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Duplicates skipped:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressDuplicates, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Errors:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressErrors, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                </StackPanel>
                <Button Content="Cancel" Background="#FF3A3A3C" Foreground="#888888"
                        BorderThickness="0" CornerRadius="4" Padding="10,6"
                        Click="OnCancelImportClick"/>
              </StackPanel>

              <!-- Step 4: Complete -->
              <StackPanel IsVisible="{Binding IsCompleteStep}" Margin="16,16" Spacing="10">
                <TextBlock Text="✓ Import Complete!" FontSize="16" FontWeight="Bold" Foreground="#34C759"/>
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Conversations imported:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressSessions, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Messages:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressMessages, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Duplicates skipped:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressDuplicates, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Errors:" Foreground="#888888" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressErrors, StringFormat='{}{0:N0}'}"
                               Foreground="White" FontSize="12"/>
                  </Grid>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Import More" Background="#FF3A3A3C" Foreground="White"
                          BorderThickness="0" CornerRadius="4" Padding="10,6"
                          Click="OnImportMoreClick"/>
                  <Button Content="Done" Background="#FF0A84FF" Foreground="White"
                          BorderThickness="0" CornerRadius="4" Padding="10,6"
                          Click="OnImportDoneClick"/>
                </StackPanel>
              </StackPanel>

            </Panel>

            <!-- Divider (only visible when history exists) -->
            <Border Height="1" Background="#FF3A3A3C" Margin="16,4,16,0"
                    IsVisible="{Binding HasImportHistory}"/>

            <!-- IMPORT HISTORY section (TRAY-6) — always visible below wizard -->
            <StackPanel IsVisible="{Binding HasImportHistory}" Margin="0,4,0,0">
              <TextBlock Text="IMPORT HISTORY" Classes="sectionHeader"/>

              <!-- Re-import error message -->
              <Border IsVisible="{Binding HasReImportMessage}"
                      Background="#3A1A1A" CornerRadius="4" Padding="12,6" Margin="16,0,16,4">
                <TextBlock Text="{Binding ImportReImportMessage}" FontSize="11"
                           Foreground="#FF6B6B" TextWrapping="Wrap"/>
              </Border>

              <ItemsControl ItemsSource="{Binding ImportHistory}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="featureRow">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Source dot -->
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                          <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding Source, Converter={x:Static StringConverters.IsNotNullOrEmpty}, ConverterParameter=#0A84FF}"/>
                          </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding ImportedAt, StringFormat='MMM d'}"
                                       FontSize="12" Foreground="White"/>
                            <TextBlock Text="{Binding Source}" FontSize="12" Foreground="#888888"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding SessionsImported, StringFormat='{}{0:N0} convs'}"
                                       FontSize="11" Foreground="#888888"/>
                            <TextBlock Text="·" FontSize="11" Foreground="#555555"/>
                            <TextBlock Text="{Binding MessagesImported, StringFormat='{}{0:N0} msgs'}"
                                       FontSize="11" Foreground="#888888"/>
                          </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Re-import"
                                Background="Transparent" Foreground="#0A84FF"
                                BorderThickness="0" FontSize="11" Padding="8,4"
                                Click="OnReImportClick"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Last import timestamp -->
              <TextBlock Text="{Binding ImportLastImportText}"
                         FontSize="11" Foreground="#555555"
                         Margin="16,4,16,8"/>
            </StackPanel>

            <!-- COLLECTION STATS section (from TRAY-8 sync stats) -->
            <StackPanel IsVisible="{Binding HasImportHistory}" Margin="0,0,0,8">
              <TextBlock Text="COLLECTION STATS" Classes="sectionHeader"/>
              <Border Classes="featureRow">
                <StackPanel Orientation="Vertical" Spacing="3">
                  <TextBlock Text="{Binding TotalConversationsText}" FontSize="12" Foreground="White"/>
                  <TextBlock Text="{Binding TotalMessagesText}"      FontSize="12" Foreground="White"/>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Oldest:" FontSize="11" Foreground="#888888"/>
                    <TextBlock Text="{Binding OldestConversationText}" FontSize="11" Foreground="#888888"/>
                    <TextBlock Text="· Newest:" FontSize="11" Foreground="#888888"/>
                    <TextBlock Text="{Binding NewestConversationText}" FontSize="11" Foreground="#888888"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

          </StackPanel>

          <!-- Settings tab -->
          <StackPanel IsVisible="{Binding IsSettingsTab}" Margin="16,16" Spacing="12">
            <TextBlock Text="ACCOUNT" Classes="sectionHeader" Margin="0,0,0,4"/>
            <Border Classes="featureRow">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Vertical">
                  <TextBlock Text="{Binding UserDisplayName}" FontSize="13" Foreground="White"/>
                  <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#888888"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Sign Out"
                        FontSize="12" Background="Transparent" Foreground="#888888"
                        BorderThickness="0" Click="OnSignOutClick"/>
              </Grid>
            </Border>
            <TextBlock Text="Settings — more options coming soon"
                       FontSize="13" Foreground="#888888" TextWrapping="Wrap" Margin="0,8,0,0"/>
          </StackPanel>

          </Panel>
        </ScrollViewer>
      </Border>

    </DockPanel>
  </Border>
</Window>
